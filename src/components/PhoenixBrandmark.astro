---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import PhoenixBrandmark_Inverse from "../../src/images/Branding/PhoenixBrandmark_Inverse.png";
import PhoenixBrandmark_Color from "../../src/images/Branding/PhoenixBrandmark_Color.png";
---

<Image
  src={PhoenixBrandmark_Inverse}
  alt="Company Brandmark, Phoenix Logo with B in center of chest"
  class="Brandmark Brandmark--Inverse"
/>
<Image
  src={PhoenixBrandmark_Color}
  alt="Company Brandmark, Phoenix Logo with B in center of chest"
  class="Brandmark Brandmark--Color"
/>
